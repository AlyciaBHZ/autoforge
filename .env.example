# AutoForge Configuration
# Copy this file to .env and fill in at least one LLM provider API key (or use OAuth)

# ── LLM Provider API Keys (at least one required, or configure OAuth below) ──
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# ── OpenAI: Custom endpoint (Azure OpenAI, LiteLLM proxy) ──
# OPENAI_BASE_URL=https://your-proxy.com/v1

# ── Google: Application Default Credentials ──
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Amazon Bedrock: Claude via AWS ──
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Google Vertex AI: Claude via Google Cloud ──
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-project-id
# CLOUD_ML_REGION=us-east5

# ── Model Selection ──
# FORGE_MODEL_STRONG=claude-opus-4-6
# FORGE_MODEL_FAST=claude-sonnet-4-5-20250929

# Optional: Budget limit in USD (default: 10.0)
# FORGE_BUDGET_LIMIT=10.0

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# FORGE_LOG_LEVEL=INFO

# Optional: Maximum parallel agents (default: 3)
# FORGE_MAX_AGENTS=3

# ── Daemon Mode ──

# Daemon poll interval in seconds (default: 10)
# FORGE_DAEMON_POLL_INTERVAL=10

# ── Telegram Bot (optional) ──
# Create a bot via @BotFather on Telegram to get the token
# FORGE_TELEGRAM_TOKEN=
# Comma-separated Telegram user IDs or usernames (empty = allow all)
# FORGE_TELEGRAM_ALLOWED_USERS=

# ── Webhook API (optional) ──
# FORGE_WEBHOOK_ENABLED=false
# FORGE_WEBHOOK_HOST=127.0.0.1
# FORGE_WEBHOOK_PORT=8420
# Bearer token for API authentication (empty = no auth)
# FORGE_WEBHOOK_SECRET=
