# AutoForge Configuration
# Copy this file to .env and fill in at least one LLM provider API key (or use OAuth)

# ── LLM Provider API Keys (at least one required, or configure OAuth below) ──
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# ── OpenAI: Custom endpoint (Azure OpenAI, LiteLLM proxy) ──
# OPENAI_BASE_URL=https://your-proxy.com/v1

# ── Google: Application Default Credentials ──
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Amazon Bedrock: Claude via AWS ──
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Google Vertex AI: Claude via Google Cloud ──
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-project-id
# CLOUD_ML_REGION=us-east5

# ── Model Selection ──
# FORGE_MODEL_STRONG=claude-opus-4-6
# FORGE_MODEL_FAST=claude-sonnet-4-6

# Optional: Budget limit in USD (default: 10.0)
# FORGE_BUDGET_LIMIT=10.0

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# FORGE_LOG_LEVEL=INFO

# Optional: Maximum parallel agents (default: 3)
# FORGE_MAX_AGENTS=3

# ── Daemon Mode ──

# Daemon poll interval in seconds (default: 10)
# FORGE_DAEMON_POLL_INTERVAL=10
# Max concurrent project workers in daemon (default: 1)
# FORGE_DAEMON_MAX_CONCURRENT_PROJECTS=1
# PID file location for daemon lifecycle commands
# FORGE_DAEMON_PID_FILE=.autoforge/daemon.pid

# ── Intake Limits (CLI queue, Telegram, Webhook) ──
# Global queued-project cap
# FORGE_QUEUE_MAX_SIZE=200
# Max active queued/building projects per requester
# FORGE_REQUESTER_QUEUE_LIMIT=3
# Max total requests per requester in 24h
# FORGE_REQUESTER_DAILY_LIMIT=20
# Burst limit window settings
# FORGE_REQUESTER_RATE_LIMIT=5
# FORGE_REQUESTER_RATE_WINDOW_SECONDS=60
# Request validation limits
# FORGE_REQUEST_MAX_BUDGET_USD=1000
# FORGE_REQUEST_MAX_DESCRIPTION_CHARS=10000

# ── Telegram Bot (optional) ──
# Create a bot via @BotFather on Telegram to get the token
# FORGE_TELEGRAM_TOKEN=
# Comma-separated Telegram user IDs or usernames
# FORGE_TELEGRAM_ALLOWED_USERS=
# Optional: set true to allow any Telegram user (not recommended for public bots)
# FORGE_TELEGRAM_ALLOW_PUBLIC=false

# ── Webhook API (optional) ──
# FORGE_WEBHOOK_ENABLED=false
# FORGE_WEBHOOK_HOST=127.0.0.1
# FORGE_WEBHOOK_PORT=8420
# Bearer token for API authentication (required unless explicitly disabled below)
# FORGE_WEBHOOK_SECRET=
# Require auth middleware (default true)
# FORGE_WEBHOOK_REQUIRE_AUTH=true
# Allow unauthenticated mode for localhost only (default false)
# FORGE_WEBHOOK_ALLOW_UNAUTH_LOCAL=false
# Optional admin override secret for cross-requester queries/cancels
# FORGE_WEBHOOK_ADMIN_SECRET=
# Optional requester/idempotency headers
# FORGE_WEBHOOK_REQUESTER_HEADER=X-Autoforge-Requester
# Trust requester header from clients (default false; keep false unless behind trusted gateway)
# FORGE_WEBHOOK_TRUST_REQUESTER_HEADER=false
# FORGE_WEBHOOK_IDEMPOTENCY_HEADER=Idempotency-Key
