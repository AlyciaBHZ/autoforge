# AutoForge Configuration
# Copy this file to .env and fill in your API key

# Required: Anthropic API Key
ANTHROPIC_API_KEY=

# Optional: Model selection
# FORGE_MODEL_STRONG=claude-opus-4-6
# FORGE_MODEL_FAST=claude-sonnet-4-5-20250929

# Optional: Budget limit in USD (default: 10.0)
# FORGE_BUDGET_LIMIT=10.0

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# FORGE_LOG_LEVEL=INFO

# Optional: Maximum parallel agents (default: 3)
# FORGE_MAX_AGENTS=3
