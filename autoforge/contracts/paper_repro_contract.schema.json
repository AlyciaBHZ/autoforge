{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autoforge/contracts/paper_repro_contract.schema.json",
  "title": "Paper Reproduction Contract Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "paper_id",
    "goal",
    "mode",
    "profile",
    "artifacts_complete",
    "pass_fail",
    "p0_p4_status",
    "failure_reasons",
    "strict_contract",
    "output_dir",
    "manifest_path",
    "report_path",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "paper-repro-contract-v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "paper_id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "artifact_only",
        "simulated_no_api_key",
        "generated_with_api_key",
        "generation_failed"
      ]
    },
    "profile": {
      "type": "string",
      "enum": [
        "theory-first",
        "general"
      ]
    },
    "artifacts_complete": {
      "type": "boolean"
    },
    "pass_fail": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "p0_p4_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "P0_api_key_runtime",
        "P1_goal_to_paper_retrieval",
        "P2_paper_signal_extraction",
        "P3_closed_loop_verification",
        "P4_environment_reproducibility"
      ],
      "properties": {
        "P0_api_key_runtime": {
          "type": "string",
          "minLength": 1
        },
        "P1_goal_to_paper_retrieval": {
          "type": "string",
          "minLength": 1
        },
        "P2_paper_signal_extraction": {
          "type": "string",
          "minLength": 1
        },
        "P3_closed_loop_verification": {
          "type": "string",
          "minLength": 1
        },
        "P4_environment_reproducibility": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "failure_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "strict_contract": {
      "type": "boolean"
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "report_path": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
